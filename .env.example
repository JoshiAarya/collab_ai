# Docker Compose Environment Variables
# Copy this file to `.env` (same directory as docker-compose.yml) and fill in values.
# `docker compose up --build` reads these automatically.

# === Required ===

# Your Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# 64-char hex key used to encrypt per-project API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex

# === Optional (have sensible defaults in docker-compose.yml) ===

# Override the JWT signing secret (defaults to an insecure value — change for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Optional: Email Configuration (for invite emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@collabai.com

# Optional: Google OAuth (auth is stubbed for MVP)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# Note: MONGODB_URI, PORT, NODE_ENV, and CORS_ORIGINS are set directly in
# docker-compose.yml and do not need to be provided here.
