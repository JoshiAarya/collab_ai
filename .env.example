# Docker Compose Environment Variables
# Copy this file to .env and update with your values

# MongoDB Configuration (required)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-me-strong-password

# Backend Configuration
NODE_ENV=production
PORT=8080

# Security (required — server refuses to start in production without these)
# Generate JWT_SECRET with: openssl rand -base64 48
JWT_SECRET=
# Generate ENCRYPTION_KEY with: openssl rand -hex 32  (must be 64 hex chars)
ENCRYPTION_KEY=

# AI (required)
GROQ_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: Email invites (SendGrid)
# SENDGRID_API_KEY=
# FROM_EMAIL=noreply@collabai.com

# FRONTEND_URL — the origin the app is served from; OAuth/email links point
# here. In the Docker container and in production the frontend is same-origin
# with the backend, so use the app's own URL (NOT the :5173 Vite dev port):
#   Docker (local):  http://localhost:8080
#   Render:          https://collabai.onrender.com
# FRONTEND_URL=http://localhost:8080

# Optional: Google OAuth (the flow is already implemented; just configure these)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI must exactly match an Authorized redirect URI in Google Cloud:
#   Docker (local):  http://localhost:8080/api/auth/google/callback
#   Render:          https://collabai.onrender.com/api/auth/google/callback
# GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Optional: Rate limits (AI requests per minute)
# RATE_LIMIT_USER_PER_MIN=20
# RATE_LIMIT_PROJECT_PER_MIN=50
