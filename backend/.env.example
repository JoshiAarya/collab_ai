# CollabAI Backend Configuration

# Server
NODE_ENV=production
PORT=8080
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/collabai

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AI Services
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key-optional
ANTHROPIC_API_KEY=your-anthropic-api-key-optional
GOOGLE_API_KEY=your-google-gemini-api-key-optional

# Google OAuth (for login)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Email Service (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@collabai.com
FROM_NAME=CollabAI

# Encryption (PHASE 4) - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# Embeddings (PHASE 2) - Local, no API key needed
HF_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
CHUNK_SIZE=900
CHUNK_OVERLAP=100

# Rate Limiting
RATE_LIMIT_USER_PER_MIN=20
RATE_LIMIT_PROJECT_PER_MIN=50

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
