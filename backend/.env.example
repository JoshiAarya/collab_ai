# Groq API Key (Llama models - get free key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Legacy Gemini API Key (optional fallback)
CHATBOT_API_KEY=your_gemini_api_key_here

# Server Port
PORT=8080

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/collab-ai

# JWT Secret for authentication (change this!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
